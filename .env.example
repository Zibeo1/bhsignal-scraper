APP_NAME=klix-scraper-service
ENVIRONMENT=development
API_PREFIX=/api/v1

DATABASE_URL=sqlite:///./data/scraper.db

KLIX_RSS_URL=https://www.klix.ba/rss
REQUEST_TIMEOUT_SECONDS=20
USER_AGENT=GeoNewsScraperBot/0.1 (+https://example.org/geonews)

SCHEDULER_ENABLED=true
RUN_SCRAPE_ON_STARTUP=false
SCRAPE_INTERVAL_SECONDS=300
SCRAPE_BATCH_LIMIT=200

OUTBOX_DISPATCH_INTERVAL_SECONDS=20
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_RETRY_BASE_SECONDS=30

WEBHOOK_TARGET_URL=
WEBHOOK_SECRET=change-me
WEBHOOK_TIMEOUT_SECONDS=10

LOCATION_CATALOG_PATH=./app/data/location_catalog.json
